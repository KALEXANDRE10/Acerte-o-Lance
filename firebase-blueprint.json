{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information with role and subscription details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "admin"] },
        "subscription": {
          "type": "object",
          "properties": {
            "plan": { "type": "string", "enum": ["free", "starter", "pro"] },
            "limit": { "type": "number" }
          }
        },
        "usage": {
          "type": "object",
          "properties": {
            "analysisCount": { "type": "number" },
            "lastReset": { "type": "string", "format": "date-time" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Vehicle stored in personal patio",
      "type": "object",
      "properties": {
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "string" },
        "fipeValue": { "type": "number" },
        "auctionValue": { "type": "number" },
        "margin": { "type": "number" },
        "authorUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "details": { "type": "object" }
      },
      "required": ["brand", "model", "authorUid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document and parameters"
    },
    "/vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "Vehicles saved in user patios"
    }
  }
}
